              "curated",
              "public_beta",
              "mcp_registry",
              "public_beta_mcp"
            ],
            "default": "sample",
            "description": "Local AOI data scope. Default remains sample."
          }
        }
      },
      "output_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": [],
        "properties": {
          "object": {
            "type": "object"
          },
          "score": {
            "type": "object"
          },
          "source_traces": {
            "type": "array"
          },
          "read_only": {
            "const": true
          },
          "data_scope": {
            "type": "string"
          }
        }
      }
    },
