{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-objective-index.example/schemas/source_trace.schema.json",
  "title": "SourceTrace",
  "description": "A source trace connecting one AOI object field to evidence from a URL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "object_id",
    "field",
    "source_url",
    "source_title",
    "source_snippet",
    "retrieved_at",
    "confidence"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[a-z0-9][a-z0-9-]*$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^aoi-[a-z0-9][a-z0-9-]*$"
    },
    "field": {
      "type": "string",
      "minLength": 1,
      "description": "Dot-path or top-level field supported by the trace."
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "source_title": {
      "type": "string",
      "minLength": 1
    },
    "source_snippet": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}

