{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-objective-index.example/schemas/action_object.schema.json",
  "title": "ActionObject",
  "description": "An object that can be ranked or compared by AOI. v0.1 objects are read-only records, not executable actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_id",
    "name",
    "object_type",
    "summary",
    "official_url",
    "source_urls",
    "capabilities",
    "categories",
    "pricing",
    "policies",
    "docs",
    "status",
    "confidence",
    "missing_fields",
    "last_checked_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^aoi-[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "object_type": {
      "type": "string",
      "enum": [
        "api",
        "saas",
        "mcp_server",
        "open_source_framework",
        "gateway",
        "database",
        "desktop_app",
        "workflow_tool",
        "monitoring_tool",
        "data_tool"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "official_url": {
      "type": "string",
      "format": "uri"
    },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "free_tier",
        "starting_price_usd",
        "currency",
        "notes"
      ],
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "free",
            "freemium",
            "usage_based",
            "seat_based",
            "open_source",
            "enterprise",
            "unknown"
          ]
        },
        "free_tier": {
          "type": "boolean"
        },
        "starting_price_usd": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commercial_use",
        "data_retention",
        "rate_limits",
        "terms_url",
        "privacy_url"
      ],
      "properties": {
        "commercial_use": {
          "type": "string"
        },
        "data_retention": {
          "type": "string"
        },
        "rate_limits": {
          "type": "string"
        },
        "terms_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "privacy_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "docs_url",
        "api_reference_url",
        "quickstart_url"
      ],
      "properties": {
        "docs_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "api_reference_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "quickstart_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "beta",
        "deprecated",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "last_checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}

