{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/aoi/schemas/agent/capability_decision_packet.schema.json",
  "title": "AOI Capability Decision Packet",
  "type": "object",
  "required": [
    "schema_version",
    "packet_id",
    "objective",
    "capability_id",
    "capability_name",
    "candidate_source",
    "capability_type",
    "objective_fit_score",
    "source_trace_status",
    "source_trace_refs",
    "metadata_completeness",
    "freshness_status",
    "version_pin",
    "last_checked_at",
    "stale_warning",
    "rugpull_diff_status",
    "known_negative_cache_hit",
    "action_level",
    "data_boundary",
    "auth_scope_required",
    "current_auth_context_known",
    "discovered_state",
    "trusted_state",
    "authorized_state",
    "executable_state",
    "route_decision",
    "route_reason_codes",
    "missing_fields",
    "safe_next_action",
    "blocked_next_actions",
    "escalation_path",
    "must_not_claim",
    "receipt_id",
    "decision_timestamp",
    "recheck_policy",
    "claim_ceiling"
  ],
  "properties": {
    "schema_version": { "const": "AOI_CapabilityDecisionPacket/v0.1" },
    "packet_id": { "type": "string" },
    "objective": { "type": "string" },
    "capability_id": { "type": "string" },
    "capability_name": { "type": "string" },
    "candidate_source": { "type": "string" },
    "capability_type": { "type": "string" },
    "objective_fit_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_trace_refs": { "type": "array", "items": { "type": "string" } },
    "known_negative_cache_hit": { "type": "boolean" },
    "current_auth_context_known": { "type": "boolean" },
    "route_reason_codes": { "type": "array", "items": { "type": "string" } },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "blocked_next_actions": { "type": "array", "items": { "type": "string" } },
    "must_not_claim": { "type": "array", "items": { "type": "string" } },
    "claim_ceiling": { "type": "array", "items": { "type": "string" } },
    "external_action_authorization": { "const": false },
    "security_certification": { "const": false },
    "product_readiness_claim": { "const": false },
    "private_kernel_exposed": { "const": false }
  },
  "additionalProperties": true
}
