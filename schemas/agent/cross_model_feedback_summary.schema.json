{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/aoi/schemas/agent/cross_model_feedback_summary.schema.json",
  "title": "AOI Cross Model Feedback Summary",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "packet_count",
    "categories_by_model",
    "cross_model_consensus",
    "disagreements_or_tensions",
    "roadmap_deltas",
    "recommended_next_package"
  ],
  "properties": {
    "schema": { "const": "AOI_CrossModelFeedbackSummary/v0.1" },
    "generated_at": { "type": "string" },
    "packet_count": { "type": "integer", "minimum": 0 },
    "models": { "type": "array", "items": { "type": "string" } },
    "categories_by_model": { "type": "object" },
    "category_counts": { "type": "object" },
    "models_by_category": { "type": "object" },
    "all_models_direction_useful": { "type": "boolean" },
    "simple_registry_insufficient": { "type": "boolean" },
    "route_preflight_governance_model_count": { "type": "integer" },
    "adoption_friction_or_latency_model_count": { "type": "integer" },
    "cross_model_consensus": { "type": "array", "items": { "type": "string" } },
    "disagreements_or_tensions": { "type": "array", "items": { "type": "string" } },
    "roadmap_deltas": { "type": "array", "items": { "type": "string" } },
    "recommended_next_package": { "type": "string" }
  },
  "additionalProperties": true
}
