{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/aoi/schemas/agent/external_model_feedback_packet.schema.json",
  "title": "AOI External Model Feedback Packet",
  "type": "object",
  "required": [
    "schema",
    "packet_id",
    "generated_at",
    "model_name",
    "prompt_set",
    "key_positive_findings",
    "key_adoption_blockers",
    "recommended_killer_features",
    "route_semantics_recommendations",
    "freshness_or_rugpull_recommendations",
    "enterprise_or_operator_positioning",
    "claim_boundary_warnings",
    "overclaim_risks",
    "direct_quotes_short_safe_only",
    "redaction_status",
    "external_llm_api_called",
    "private_kernel_exposed"
  ],
  "properties": {
    "schema": { "const": "AOI_ExternalModelFeedbackPacket/v0.1" },
    "packet_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "model_name": { "type": "string" },
    "prompt_set": { "type": "string" },
    "overall_rating_if_present": { "type": "string" },
    "key_positive_findings": { "type": "array", "items": { "type": "string" } },
    "key_adoption_blockers": { "type": "array", "items": { "type": "string" } },
    "recommended_killer_features": { "type": "array", "items": { "type": "string" } },
    "route_semantics_recommendations": { "type": "array", "items": { "type": "string" } },
    "freshness_or_rugpull_recommendations": { "type": "array", "items": { "type": "string" } },
    "enterprise_or_operator_positioning": { "type": "array", "items": { "type": "string" } },
    "claim_boundary_warnings": { "type": "array", "items": { "type": "string" } },
    "overclaim_risks": { "type": "array", "items": { "type": "string" } },
    "direct_quotes_short_safe_only": { "type": "array", "items": { "type": "string" } },
    "redaction_status": { "enum": ["PASS_REDACTED", "HOLD_REVIEW_RECOMMENDED", "BLOCK_SENSITIVE_CONTENT"] },
    "token_or_secret_detected": { "type": "boolean" },
    "external_llm_api_called": { "type": "boolean" },
    "raw_transcript_stored": { "type": "boolean" },
    "private_kernel_exposed": { "type": "boolean" },
    "claim_boundary": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
