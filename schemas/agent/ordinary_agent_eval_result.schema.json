{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AOI Ordinary Agent Eval Result",
  "type": "object",
  "required": [
    "schema",
    "case_id",
    "objective",
    "mode",
    "top_candidates",
    "route_decision",
    "score",
    "max_score"
  ],
  "properties": {
    "schema": {
      "enum": [
        "AOI_NaiveAgentBaselineResult/v0.1",
        "AOI_GuidedAgentEvalResult/v0.1"
      ]
    },
    "case_id": { "type": "string" },
    "objective": { "type": "string" },
    "mode": { "type": "string" },
    "top_candidates": { "type": "array" },
    "source_traces": { "type": "array" },
    "missing_fields": { "type": "array" },
    "route_decision": { "type": "string" },
    "next_action": { "type": "string" },
    "must_not_claim": { "type": "array" },
    "residualops_escalation": {},
    "freshness": {},
    "score": { "type": "integer" },
    "max_score": { "type": "integer" }
  }
}
