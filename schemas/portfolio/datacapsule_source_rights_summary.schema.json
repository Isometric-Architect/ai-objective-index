{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/portfolio/datacapsule_source_rights_summary.schema.json",
  "title": "DataCapsule Source Rights Summary",
  "type": "object",
  "required": ["schema", "summary_id", "manifest_id", "rights_status", "missing_fields", "warnings", "must_not_claim"],
  "properties": {
    "schema": { "const": "ResidualOps_DataCapsuleSourceRightsSummary/v0.1" },
    "summary_id": { "type": "string" },
    "manifest_id": { "type": "string" },
    "license_found": { "type": "boolean" },
    "terms_found": { "type": "boolean" },
    "source_attribution_found": { "type": "boolean" },
    "collection_method_found": { "type": "boolean" },
    "rights_status": { "type": "string" },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "must_not_claim": { "type": "array", "items": { "type": "string" } }
  }
}
