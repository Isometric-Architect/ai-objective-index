{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResidualOps Feedback Reply Packet",
  "type": "object",
  "required": ["schema", "reply_id", "source", "reply_text_redacted", "consent_signal", "requested_action"],
  "properties": {
    "schema": { "const": "ResidualOps_FeedbackReplyPacket/v0.1" },
    "reply_id": { "type": "string" },
    "source": { "enum": ["sample_fixture", "local_file", "pasted_text_file", "manual_note", "unknown"] },
    "reviewer_type": { "type": "string" },
    "related_vertical": { "enum": ["agentsec", "qira", "datacapsule", "portfolio", "unknown"] },
    "reply_text_redacted": { "type": "string" },
    "consent_signal": { "enum": ["explicit_local_review_allowed", "feedback_only", "unclear", "insufficient", "sample_fixture"] },
    "requested_action": { "type": "string" },
    "external_action_requested": { "type": "boolean" },
    "token_or_secret_detected": { "type": "boolean" },
    "private_kernel_detected": { "type": "boolean" }
  },
  "additionalProperties": true
}
