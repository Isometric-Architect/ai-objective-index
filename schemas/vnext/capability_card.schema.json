{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.local/schemas/vnext/capability_card.schema.json",
  "title": "AOI vNext CapabilityCard",
  "type": "object",
  "required": ["schema", "capability_id", "provider", "name"],
  "properties": {
    "schema": {"type": "string"},
    "capability_id": {"type": "string"},
    "provider": {"type": "string"},
    "name": {"type": "string"},
    "version": {"type": ["string", "null"]},
    "integration": {"type": "object"},
    "supported_objectives": {"type": "array", "items": {"type": "string"}},
    "input_schema": {"type": "object"},
    "output_schema": {"type": "object"},
    "permission_scope": {"type": "array", "items": {"type": "string"}},
    "cost_model": {"type": "object"},
    "latency_class": {"type": "string"},
    "context_burden": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "object"}},
    "known_failures": {"type": "array", "items": {"type": "object"}},
    "allowed_use": {"type": "array", "items": {"type": "string"}},
    "hold_use": {"type": "array", "items": {"type": "string"}},
    "blocked_use": {"type": "array", "items": {"type": "string"}},
    "security": {"type": "object"},
    "maintenance": {"type": "object"}
  }
}
