{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.local/schemas/vnext/capability_graph.schema.json",
  "title": "AOI vNext CapabilityGraph",
  "type": "object",
  "required": ["schema", "nodes", "edges"],
  "properties": {
    "schema": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "node_type", "label"],
        "properties": {
          "node_id": {"type": "string"},
          "node_type": {"enum": ["Objective", "Capability", "Tool", "MCPServer", "Agent", "Dataset", "Verifier", "Benchmark", "Provider", "FailureMode", "ExecutionReceipt", "RiskBoundary"]},
          "label": {"type": "string"},
          "metadata": {"type": "object"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "edge_type"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "edge_type": {"enum": ["supports", "requires", "verified_by", "fails_under", "blocked_by", "delegates_to", "substitutes_for", "composed_with", "version_of"]},
          "evidence": {"type": "array", "items": {"type": "object"}},
          "metadata": {"type": "object"}
        }
      }
    }
  }
}
