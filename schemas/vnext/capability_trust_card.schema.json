{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-objective-index.local/schemas/vnext/capability_trust_card.schema.json",
  "title": "AOI Capability Trust Card",
  "type": "object",
  "required": [
    "schema",
    "trust_card_id",
    "objective_id",
    "capability_id",
    "name",
    "domain",
    "integration_type",
    "status",
    "source_trace_ids",
    "evidence_summary",
    "match",
    "risk_boundary",
    "route_decision",
    "score_components",
    "generated_at"
  ],
  "properties": {
    "schema": { "const": "AOI_CapabilityTrustCard/v0.1" },
    "trust_card_id": { "type": "string" },
    "objective_id": { "type": "string" },
    "capability_id": { "type": "string" },
    "object_id": { "type": ["string", "null"] },
    "name": { "type": "string" },
    "provider": { "type": ["string", "null"] },
    "domain": { "type": "string" },
    "integration_type": {
      "enum": ["api", "mcp_server", "python_package", "dataset", "service", "tool", "agent", "unknown"]
    },
    "status": { "type": "string" },
    "source_trace_ids": { "type": "array", "items": { "type": "string" } },
    "evidence_summary": { "$ref": "capability_evidence_summary.schema.json" },
    "match": { "type": "object" },
    "risk_boundary": { "$ref": "capability_risk_boundary.schema.json" },
    "route_decision": { "$ref": "capability_route_decision.schema.json" },
    "score_components": { "type": "object" },
    "residual_notes": { "type": "array", "items": { "type": "string" } },
    "missing_fields": { "type": "array", "items": { "type": "string" } },
    "known_limits": { "type": "array", "items": { "type": "string" } },
    "generated_at": { "type": "string" }
  },
  "additionalProperties": true
}
