{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.local/schemas/vnext/execution_receipt_validation_result.schema.json",
  "title": "AOI ExecutionReceiptValidationResult",
  "type": "object",
  "additionalProperties": true,
  "required": ["receipt_id", "valid", "decision"],
  "properties": {
    "schema": {"const": "AOI_ExecutionReceiptValidationResult/v0.1"},
    "receipt_id": {"type": "string"},
    "valid": {"type": "boolean"},
    "decision": {
      "enum": ["RECEIPT_ACCEPTED", "HOLD_MISSING_REQUIRED_FIELDS", "HOLD_LOW_EVIDENCE_ORIGIN", "HOLD_CONFLICTING_OUTCOME", "BLOCK_FORBIDDEN_ACTION", "BLOCK_UNSUPPORTED_CLAIM", "BLOCK_ACTION_AUTHORIZATION", "INVALID_RECEIPT"]
    },
    "errors": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "claim_ceiling": {"type": "string"},
    "can_influence_route": {"type": "boolean"},
    "can_upgrade_to_verified": {"const": false},
    "can_certify_security": {"const": false},
    "can_certify_quality": {"const": false},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "token_printed": {"const": false}
  }
}
