{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.local/schemas/vnext/objective_receipt_summary.schema.json",
  "title": "AOI ObjectiveReceiptSummary",
  "type": "object",
  "additionalProperties": true,
  "required": ["objective_id", "receipt_count"],
  "properties": {
    "schema": {"const": "AOI_ObjectiveReceiptSummary/v0.1"},
    "objective_id": {"type": "string"},
    "receipt_count": {"type": "integer"},
    "capabilities_seen": {"type": "array", "items": {"type": "string"}},
    "outcome_counts": {"type": "object", "additionalProperties": {"type": "integer"}},
    "top_failure_modes": {"type": "array", "items": {"type": "string"}},
    "route_adjustment_notes": {"type": "array", "items": {"type": "string"}},
    "known_limits": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string"}
  }
}
